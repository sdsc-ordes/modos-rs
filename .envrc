#!/usr/bin/env bash
# shellcheck disable=SC1091

# If you have `direnv` installed, this file
# will source the Nix devShell `default` directly when entering this
# directory.
if ! has nix_direnv_version || ! nix_direnv_version 3.1.2; then
    source_url "https://raw.githubusercontent.com/nix-community/nix-direnv/3.1.2/direnvrc" "sha256-Di03ad3a0ueGi6CGrfhrQzyGdQIg9APXIPCAMNQgWYM="
fi

shell="default"
if [ "$JAILED" = "true" ]; then
    # In sandboxed mode we start with out githooks.
    shell="default-nogh"
fi

use flake "./tools/nix#$shell" \
    --accept-flake-config \
    --show-trace \
    --no-pure-eval
